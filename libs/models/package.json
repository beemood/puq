{
  "name": "@puq/models",
  "version": "0.7.1",
  "description": "Add project description here...",
  "author": {
    "name": "Robert Brightline",
    "email": "robert.brightline@gmail.com",
    "url": "https://beemood.github.io"
  },
  "funding": [
    "https://cash.app/$puqlib"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "sourceRoot": "libs/models/src",
    "targets": {
      "build": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "libs/models/dist",
          "main": "libs/models/src/index.ts",
          "tsConfig": "libs/models/tsconfig.lib.json",
          "skipTypeCheck": true,
          "stripLeadingPaths": true
        }
      },
      "doc": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npx typedoc --name models --entryPoints {projectRoot}/src/index.ts --favicon {projectRoot}/favicon.png --out public/models --tsconfig {projectRoot}/tsconfig.lib.json"
        }
      }
    }
  },
  "dependencies": {
    "@puq/zod": "workspace:*",
    "@swc/helpers": "~0.5.11",
    "zod": "^4.1.3"
  }
}
